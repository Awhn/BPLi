// B PLi data model — Book = album, Chapter = track, Flow = playlist

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(cuid())
  nickname    String
  email       String?  @unique
  personality String? // PersonalityType result from the reading personality test
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  quotes          Quote[]
  comments        Comment[]
  readingStatuses ReadingStatus[]
  flows           Flow[]
  events          Event[]
}

model Book {
  id            String   @id @default(cuid())
  title         String
  subtitle      String?
  author        String
  publisher     String?
  coverImageUrl String?
  description   String?
  categories    String[]
  isbn          String?  @unique
  totalPages    Int? // total page count — powers the now-playing progress scrubber
  sourceType    String   @default("user_added") // user_added | public_api | curated | original | licensed
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  chapters        Chapter[]
  quotes          Quote[]
  comments        Comment[]
  readingStatuses ReadingStatus[]
}

model Chapter {
  id                      String   @id @default(cuid())
  bookId                  String
  title                   String
  order                   Int
  estimatedReadingMinutes Int      @default(10)
  summary                 String?
  contentAvailability     String   @default("metadata_only") // metadata_only | preview | full_content | original_content
  isOriginal              Boolean  @default(false)
  isCurated               Boolean  @default(false)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  book     Book      @relation(fields: [bookId], references: [id], onDelete: Cascade)
  quotes   Quote[]
  comments Comment[]

  @@unique([bookId, order])
}

model Flow {
  id                    String   @id @default(cuid())
  title                 String
  description           String?
  coverImageUrl         String?
  creatorId             String
  isEditorial           Boolean  @default(false)
  visibility            String   @default("public") // private | public
  items                 Json     @default("[]") // FlowItem[] — { type, refId, order }
  tags                  String[]
  mood                  String?
  estimatedTotalMinutes Int      @default(0)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  creator User @relation(fields: [creatorId], references: [id])
}

model Quote {
  id         String   @id @default(cuid())
  userId     String
  bookId     String
  chapterId  String?
  text       String
  pageNumber Int?
  imageUrl   String?
  sourceType String   @default("manual") // manual | ocr | imported
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  book     Book      @relation(fields: [bookId], references: [id], onDelete: Cascade)
  chapter  Chapter?  @relation(fields: [chapterId], references: [id])
  comments Comment[]
}

model Comment {
  id         String   @id @default(cuid())
  userId     String
  bookId     String
  chapterId  String?
  quoteId    String?
  pageNumber Int?
  body       String
  visibility String   @default("private") // private | followers | public
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  book    Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  chapter Chapter? @relation(fields: [chapterId], references: [id])
  quote   Quote?   @relation(fields: [quoteId], references: [id])
}

model ReadingStatus {
  id         String    @id @default(cuid())
  userId      String
  bookId      String
  status      String // want_to_read | reading | finished | paused
  currentPage Int? // last page the reader is on — anchors new page comments
  startedAt   DateTime?
  finishedAt  DateTime?
  updatedAt   DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([userId, bookId])
}

// Event log for Wrapped and recommendations — write from day one (CLAUDE.md §17)
model Event {
  id         String   @id @default(cuid())
  userId     String
  eventName  String
  properties Json     @default("{}")
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, eventName])
  @@index([createdAt])
}
